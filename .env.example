# ── ikas API ──────────────────────────────────────────────────────────────────
IKAS_STORE_NAME=your-store-name
IKAS_CLIENT_ID=your-client-id
IKAS_CLIENT_SECRET=your-client-secret

# ── ikas MCP (Model Context Protocol) ────────────────────────────────────────
# ikas admin panelinden MCP Client uygulamasi olusturup token alin
# Bu token ile AI modelleri magaza verilerine erisebilir (urunler, siparisler vb.)
# https://builders.ikas.com/docs/ikas-ai
IKAS_MCP_TOKEN=

# ── AI Provider ───────────────────────────────────────────────────────────────
# Options: none | anthropic | openai | gemini | openrouter | ollama | custom
AI_PROVIDER=anthropic

# API key for the selected provider
# Anthropic  → sk-ant-...
# OpenAI     → sk-...
# Gemini     → AIza...
# OpenRouter → sk-or-...
# Ollama     → (leave empty)
AI_API_KEY=

# Base URL — leave empty to use the provider default
# Ollama default  : http://localhost:11434/v1
# OpenRouter      : https://openrouter.ai/api/v1
# Custom endpoint : your URL here
AI_BASE_URL=

# Model name — leave empty to use the provider default
# anthropic  : claude-haiku-4-5-20251001
# openai     : gpt-4o-mini
# gemini     : gemini-1.5-flash
# openrouter : openai/gpt-4o-mini
# ollama     : llama3.2
AI_MODEL_NAME=

AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000

# Legacy Anthropic key (still supported for backward compatibility)
# ANTHROPIC_API_KEY=sk-ant-...

# ── General ───────────────────────────────────────────────────────────────────
STORE_LANGUAGES=tr,en
# STORE_LANGUAGE=tr  # Geriye donuk desteklenir
SEO_TARGET_KEYWORDS=keyword1,keyword2
DRY_RUN=true
LOG_LEVEL=INFO
