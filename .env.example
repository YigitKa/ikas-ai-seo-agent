# ikas API
IKAS_STORE_NAME=your-store-name
IKAS_CLIENT_ID=your-client-id
IKAS_CLIENT_SECRET=your-client-secret

# ikas MCP
# ikas admin panelinden MCP Client olusturup token alabilirsiniz.
IKAS_MCP_TOKEN=

# AI Provider
# Options: none | anthropic | openai | gemini | openrouter | ollama | lm-studio | custom
AI_PROVIDER=anthropic

# API key for the selected provider
# Anthropic  -> sk-ant-...
# OpenAI     -> sk-...
# Gemini     -> AIza...
# OpenRouter -> sk-or-...
# Ollama     -> leave empty
# LM Studio  -> leave empty in most local setups
AI_API_KEY=

# Base URL - leave empty to use the provider default
# OpenAI default   : https://api.openai.com/v1
# Gemini default   : https://generativelanguage.googleapis.com/v1beta/openai/
# OpenRouter       : https://openrouter.ai/api/v1
# Ollama default   : http://localhost:11434/v1
# LM Studio        : http://localhost:1234/v1
# Custom endpoint  : your URL here
AI_BASE_URL=

# Model name - leave empty to use the provider default
# anthropic  : claude-haiku-4-5-20251001
# openai     : gpt-4o-mini
# gemini     : gemini-1.5-flash
# openrouter : openai/gpt-4o-mini
# ollama     : llama3.2
# lm-studio  : local-model
# custom     : gpt-3.5-turbo
AI_MODEL_NAME=

AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000
AI_THINKING_MODE_CHAT=false
AI_THINKING_MODE_BATCH=false

# Legacy Anthropic key (backward compatibility)
# ANTHROPIC_API_KEY=sk-ant-...

# General
STORE_LANGUAGES=tr,en
# STORE_LANGUAGE=tr
SEO_TARGET_KEYWORDS=keyword1,keyword2
SEO_LOW_SCORE_THRESHOLD=70
DRY_RUN=true
LOG_LEVEL=INFO

# Google Search Console OAuth2 (opsiyonel)
# Kurulum:
#   1. https://console.cloud.google.com adresinde proje oluşturun
#   2. "Google Search Console API"yi etkinleştirin
#   3. "OAuth 2.0 Client ID" oluşturun (Web application türünde)
#   4. Authorized redirect URI olarak ekleyin: http://localhost:8000/api/gsc/auth/callback
#   5. Client ID ve Secret'i aşağıya girin
#   6. Uygulamayı çalıştırıp Settings → "Google ile Bağlan" butonuna tıklayın
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
GSC_REFRESH_TOKEN=       # OAuth akışından sonra otomatik doldurulur, elle girmeyin
GSC_PROPERTY_URL=        # Örn: https://www.mystore.com (GSC'de tanımlı property URL'i)
